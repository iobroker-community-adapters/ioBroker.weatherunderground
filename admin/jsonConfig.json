          "xs": 12,
          "sm": 6,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "forecast_hourly": {
          "newLine": true,
          "type": "checkbox",
          "label": "forecast_hourly",
          "xs": 12,
          "sm": 6,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "current": {
          "type": "checkbox",
          "label": "current",
          "xs": 12,
          "sm": 6,
          "md": 6,
          "lg": 6,
          "xl": 6
