        "station": {
          "type": "text",
          "label": "station",
          "hidden": "!data.current",
          "xs": 12,
          "sm": 12,
          "md": 4,
          "lg": 4,
          "xl": 4
        },
        "_country_info": {
          "newLine": true,
          "type": "staticText",
          "text": "country_info",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "_location_info": {
          "type": "staticText",
          "text": "location_info",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "_station_only": {
          "type": "staticText",
          "text": "Station - only for current conditions data",
          "hidden": "!data.current",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "_station_info": {
          "type": "staticText",
