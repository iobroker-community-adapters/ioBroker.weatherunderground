          "xs": 12,
          "sm": 6,
          "md": 4,
          "lg": 4,
          "xl": 4
        },
        "location": {
          "type": "text",
          "label": "location",
          "xs": 12,
          "sm": 6,
          "md": 4,
          "lg": 4,
          "xl": 4
