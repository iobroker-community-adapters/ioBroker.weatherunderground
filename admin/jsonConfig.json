        "uk": "Основні налаштування",
        "zh-cn": "主要设置"
      },
      "items": {
        "apikey": {
          "type": "text",
          "label": "apikey",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "_apikey_info": {
